{
  "consumer": {
    "name": "web"
  },
  "interactions": [
    {
      "description": "a request for all notifications",
      "providerStates": [
        {
          "name": "user has notifications"
        }
      ],
      "request": {
        "headers": {
          "Authorization": "Bearer test-token"
        },
        "method": "GET",
        "path": "/api/notifications"
      },
      "response": {
        "body": [
          {
            "channel": "IN_APP",
            "createdAt": "2023-01-01T00:00:00.000Z",
            "id": "some-uuid",
            "isRead": false,
            "message": "Welcome to the app",
            "title": "Welcome",
            "type": "SYSTEM"
          }
        ],
        "headers": {
          "Content-Type": "application/json; charset=utf-8"
        },
        "matchingRules": {
          "body": {
            "$": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type",
                  "min": 1
                }
              ]
            },
            "$[*].channel": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$[*].createdAt": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$[*].id": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$[*].isRead": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$[*].message": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$[*].title": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$[*].type": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 200
      }
    },
    {
      "description": "a request to mark notification as read",
      "providerStates": [
        {
          "name": "user has unread notification with id test-notif-id"
        }
      ],
      "request": {
        "headers": {
          "Authorization": "Bearer test-token"
        },
        "method": "PATCH",
        "path": "/api/notifications/test-notif-id/read"
      },
      "response": {
        "body": {
          "channel": "IN_APP",
          "createdAt": "2023-01-01T00:00:00.000Z",
          "id": "test-notif-id",
          "isRead": true,
          "message": "Welcome to the app",
          "title": "Welcome",
          "type": "SYSTEM"
        },
        "headers": {
          "Content-Type": "application/json; charset=utf-8"
        },
        "matchingRules": {
          "body": {
            "$": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.channel": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.createdAt": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.id": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.message": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.title": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.type": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 200
      }
    },
    {
      "description": "poprawne żądanie logowania",
      "providerStates": [
        {
          "name": "użytkownik demo istnieje"
        }
      ],
      "request": {
        "body": {
          "email": "demo@example.com",
          "password": "Password123!"
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "method": "POST",
        "path": "/api/auth/login"
      },
      "response": {
        "body": {
          "access_token": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
        },
        "headers": {
          "Content-Type": "application/json; charset=utf-8"
        },
        "matchingRules": {
          "body": {
            "$": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 200
      }
    }
  ],
  "metadata": {
    "pact-js": {
      "version": "16.2.0"
    },
    "pactRust": {
      "ffi": "0.4.28",
      "models": "1.3.5"
    },
    "pactSpecification": {
      "version": "3.0.0"
    }
  },
  "provider": {
    "name": "api"
  }
}