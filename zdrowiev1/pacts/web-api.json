        {
          "name": "użytkownik demo istnieje"
        }
      ],
      "request": {
        "body": {
          "email": "demo@example.com",
          "password": "Password123!"
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "method": "POST",
        "path": "/api/auth/login"
      },
      "response": {
        "body": {
          "access_token": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
