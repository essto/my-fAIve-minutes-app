{
    "compilerOptions": {
        "target": "ESNext",
        "module": "ESNext",
        "moduleResolution": "node",
        "lib": [
            "ESNext",
            "DOM"
        ],
        "strict": true,
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "skipLibCheck": true,
        "baseUrl": ".",
        "paths": {
            "@modules/*": [
                "modules/*"
            ],
            "@packages/*": [
                "packages/*"
            ],
            "@infrastructure/*": [
                "infrastructure/*"
            ]
        }
    },
    "exclude": [
        "node_modules",
        "dist"
    ]
}